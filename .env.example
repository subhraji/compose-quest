# ──────────────────────────────────────────────────────────────
# Compose Quest — AI Mentor configuration
# The mentor is provider-agnostic. Pick ONE provider below.
# If no key is set, the app runs with a friendly offline fallback.
# ──────────────────────────────────────────────────────────────

# Which provider to use: "gemini" (free, default) | "groq" | "openai" | "anthropic"
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier — recommended default) ---
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (free tier, very fast) ---
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (paid) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic / Claude (paid) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
